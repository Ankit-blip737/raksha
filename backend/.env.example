# Ollama runs locally — no API key, no internet needed after model download
OLLAMA_HOST=http://localhost:11434
PORT=4000

# Model used for signal classification (fast, cheap calls — runs on CPU fine)
CLASSIFIER_MODEL=qwen2.5:0.5b

# Model used for LLM reasoning
REASONER_MODEL=qwen2.5:0.5b

# Model used for RAG embeddings (small, high-quality)
EMBEDDING_MODEL=nomic-embed-text
